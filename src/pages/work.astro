---
import PageLayout from "@/layouts/Base.astro";

const visualizations = [
	{
		title: "Full network",
		description: "Interactive network view of industries, sectors, and linked factors.",
		href: "/network_full.html",
	},
	{
		title: "Linkages",
		description: "Explore upstream and downstream linkages in the USEEIO-derived data.",
		href: "/linkages.html",
	},
	{
		title: "Factor flows",
		description: "Review factor-flow results and supporting analysis views.",
		href: "/flow_analysis.html",
	},
	{
		title: "Network visualization",
		description: "Earlier network visualization page kept for reference.",
		href: "/network_visualization.html",
	},
];

const meta = {
	description: "Selected work by Viktoras Kulionis.",
	title: "Work",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-12">Work</h1>
	<div class="space-y-12">
		<section id="useeio" class="rounded border border-line p-5">
			<p class="mb-3 text-sm uppercase tracking-[0.3em] text-accent">Example project</p>
			<h2 class="title mb-3 text-xl">USEEIO network analysis</h2>
			<p class="mb-4 text-sm">
				A static analysis workspace for exploring USEEIO-derived economic networks, linkages,
				and factor-flow outputs. This is one example of my work, not the identity of the whole site.
			</p>
			<a class="cactus-link text-sm" href="/posts/useeio-analysis/">Read project note</a>
		</section>

		<section id="useeio-visualizations">
			<h2 class="title mb-6 text-xl">USEEIO interactive outputs</h2>
			<div class="grid gap-4 sm:grid-cols-2">
				{
					visualizations.map((item) => (
						<a class="group rounded border border-line p-4 transition hover:border-accent" href={item.href}>
							<h3 class="title mb-2 text-lg group-hover:text-accent">{item.title}</h3>
							<p class="text-sm">{item.description}</p>
						</a>
					))
				}
			</div>
		</section>
	</div>
</PageLayout>
