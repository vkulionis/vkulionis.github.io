---

<PageLayout meta={meta}>
	<section>
		<p class="mb-3 text-sm uppercase tracking-[0.3em] text-accent">Research</p>
		<h1 class="title mb-6">Research</h1>
		<p class="mb-4 max-w-2xl">
			My research focuses on environmental and economic systems, including input-output analysis,
			energy transitions, carbon footprints, planetary boundaries, biodiversity impacts, and sustainable development.
		</p>
		<p class="text-sm">
			Source: <a class="cactus-link" href={scholarProfile} rel="noreferrer" target="_blank">Google Scholar profile</a>
			<span class="text-muted"> · Institute of Environmental Engineering, ETH Zürich · cited by 971 on Google Scholar when checked</span>
		</p>
	</section>

	<section class="mt-12">
		<h2 class="title mb-4 text-xl">Research areas</h2>
		<div class="flex flex-wrap gap-2">
			{
				researchAreas.map((area) => (
					<span class="rounded border border-line px-3 py-1 text-sm text-muted">{area}</span>
				))
			}
		</div>
	</section>

	<section class="mt-12">
		<h2 class="title mb-6 text-xl">Selected publications</h2>
		<ol class="space-y-5" role="list">
			{
				publications.map((publication) => (
					<li class="border-b border-line pb-5 last:border-b-0">
						<div class="text-muted text-xs font-semibold uppercase tracking-[0.2em]">{publication.year}</div>
						<h3 class="title mt-1 text-base">{publication.title}</h3>
						<p class="mt-1 text-sm">{publication.authors}</p>
						<p class="text-muted mt-1 text-sm">{publication.venue}</p>
					</li>
				))
			}
		</ol>
	</section>
</PageLayout>
