---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description: "About Viktoras Kulionis and this personal website.",
	title: "About",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-12">About</h1>
	<div class="prose prose-sm prose-cactus max-w-none">
		<p>
			This is the personal website of Viktoras Kulionis: a simple place for selected work,
			writing, and experiments.
		</p>
		<p>
			The USEEIO analysis is one project example. Its interactive outputs are kept together on a
			separate <a class="cactus-link" href="/visualizations/">visualizations page</a> so the homepage
			can stay focused on the broader personal profile.
		</p>
		<p>
			The site is built with Astro and published through GitHub Pages.
		</p>
	</div>
</PageLayout>
