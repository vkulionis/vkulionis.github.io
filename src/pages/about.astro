---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description: "About Viktoras Kulionis and this personal website.",
	title: "About",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-12">About</h1>
	<div class="prose prose-sm prose-cactus max-w-none">
		<p>
			This is the personal website of Viktoras Kulionis: a simple place for selected work,
			writing, research, and experiments.
		</p>
		<p>
			The USEEIO analysis is one project example. Its interactive outputs are grouped under
			<a class="cactus-link" href="/work/#useeio-visualizations">Work</a> so project artifacts stay
			with the project.
		</p>
		<p>
			The site is built with Astro and published through GitHub Pages.
		</p>
	</div>
</PageLayout>
