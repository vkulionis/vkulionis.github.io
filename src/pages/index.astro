---
import { type CollectionEntry } from "astro:content";
import PostPreview from "@/components/blog/PostPreview.astro";
import SocialList from "@/components/SocialList.astro";
import { getAllPosts } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

const allPosts = await getAllPosts();
const latestPosts = allPosts.sort(collectionDateSort).slice(0, 3) as CollectionEntry<"post">[];

const work = [
	{
		title: "USEEIO network analysis",
		description:
			"An input-output analysis project with interactive network, linkage, and factor-flow visualizations.",
		href: "/work/#useeio",
	},
];
---

<PageLayout meta={{ title: "Home" }}>
	<section>
		<p class="mb-3 text-sm uppercase tracking-[0.3em] text-accent">Personal website</p>
		<h1 class="title mb-6">Viktoras Kulionis</h1>
		<p class="mb-4 max-w-2xl">
			I build analytical tools and data-driven projects. This site is a simple home for selected
			work, notes, and experiments.
		</p>
		<SocialList />
	</section>

	<section class="mt-16">
		<h2 class="title mb-6 text-xl">Selected work</h2>
		<div class="grid gap-4 sm:grid-cols-2">
			{
				work.map((item) => (
					<a class="group rounded border border-line p-4 transition hover:border-accent" href={item.href}>
						<h3 class="title mb-2 text-lg group-hover:text-accent">{item.title}</h3>
						<p class="text-sm">{item.description}</p>
					</a>
				))
			}
		</div>
		<p class="mt-4 text-sm">
			All USEEIO interactive outputs are grouped on the <a class="cactus-link" href="/visualizations/">visualizations page</a>.
		</p>
	</section>

	<section class="mt-16">
		<h2 class="title text-accent mb-6 text-xl"><a href="/posts/">Latest posts</a></h2>
		<ul class="space-y-4" role="list">
			{latestPosts.map((p) => <li class="grid gap-1 sm:grid-cols-[auto_1fr]"><PostPreview post={p} /></li>)}
		</ul>
	</section>
</PageLayout>
