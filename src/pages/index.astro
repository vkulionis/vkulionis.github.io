---
import { type CollectionEntry } from "astro:content";
import PostPreview from "@/components/blog/PostPreview.astro";
import SocialList from "@/components/SocialList.astro";
import { getAllPosts } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

const allPosts = await getAllPosts();
const latestPosts = allPosts.sort(collectionDateSort).slice(0, 5) as CollectionEntry<"post">[];

const researchHighlights = [
	{
		title: "Global carbon footprints: a detailed look at affluence and technology effects",
		meta: "Environmental Research Communications, 2025",
	},
	{
		title: "Biodiversity impact assessment for finance",
		meta: "Journal of Industrial Ecology, 2024",
	},
	{
		title: "Multiscale orientation values for biodiversity, climate and water",
		meta: "arXiv preprint, 2024",
	},
	{
		title: "Mapping GHG emissions and prospects for renewable energy in the chemical industry",
		meta: "Current Opinion in Chemical Engineering, 2023",
	},
	{
		title: "A planetary boundary-based method to assess freshwater use at the global and local scales",
		meta: "Environmental Research Letters, 2022",
	},
];

const workHighlights = [
	{
		title: "USEEIO network analysis",
		description: "Input-output analysis project with interactive network, linkage, and factor-flow outputs.",
		href: "/work/#useeio",
	},
	{
		title: "Full network visualization",
		description: "Interactive view of industries, sectors, and linked factors.",
		href: "/network_full.html",
	},
	{
		title: "Linkages explorer",
		description: "Upstream and downstream linkages in the USEEIO-derived data.",
		href: "/linkages.html",
	},
	{
		title: "Factor-flow analysis",
		description: "Factor-flow results and supporting analysis views.",
		href: "/flow_analysis.html",
	},
];
---

<PageLayout meta={{ title: "Home" }}>
	<section>
		<p class="mb-3 text-sm uppercase tracking-[0.3em] text-accent">Personal website</p>
		<h1 class="title mb-6">Viktoras Kulionis</h1>
		<p class="mb-4 max-w-2xl">
			I build analytical tools and data-driven projects. This site is a simple home for selected
			work, research, notes, and experiments.
		</p>
		<SocialList />
	</section>

	<section class="mt-16">
		<div class="mb-6 flex items-baseline justify-between gap-4">
			<h2 class="title text-xl">Research</h2>
			<a class="cactus-link text-sm" href="/research/">View all</a>
		</div>
		<p class="mb-5 max-w-2xl text-sm">
			Selected recent and popular publications on input-output analysis, carbon footprints,
			planetary boundaries, biodiversity impacts, and sustainable development.
		</p>
		<ul class="space-y-3" role="list">
			{
				researchHighlights.map((item) => (
					<li class="border-b border-line pb-3 last:border-b-0">
						<a class="group block" href="/research/">
							<h3 class="title text-base group-hover:text-accent">{item.title}</h3>
							<p class="text-muted mt-1 text-sm">{item.meta}</p>
						</a>
					</li>
				))
			}
		</ul>
	</section>

	<section class="mt-16">
		<div class="mb-6 flex items-baseline justify-between gap-4">
			<h2 class="title text-xl">Work</h2>
			<a class="cactus-link text-sm" href="/work/">View all</a>
		</div>
		<ul class="space-y-3" role="list">
			{
				workHighlights.map((item) => (
					<li class="border-b border-line pb-3 last:border-b-0">
						<a class="group block" href={item.href}>
							<h3 class="title text-base group-hover:text-accent">{item.title}</h3>
							<p class="text-muted mt-1 text-sm">{item.description}</p>
						</a>
					</li>
				))
			}
		</ul>
	</section>

	<section class="mt-16">
		<div class="mb-6 flex items-baseline justify-between gap-4">
			<h2 class="title text-xl">Latest posts</h2>
			<a class="cactus-link text-sm" href="/posts/">View all</a>
		</div>
		<ul class="space-y-4" role="list">
			{latestPosts.map((p) => <li class="grid gap-1 sm:grid-cols-[auto_1fr]"><PostPreview post={p} /></li>)}
		</ul>
	</section>
</PageLayout>
